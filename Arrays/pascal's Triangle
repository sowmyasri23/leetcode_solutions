class Solution:
    def generate(self, numRows: int) -> List[List[int]]:
        if numRows == 0:
            return []
        if numRows == 1:
            return [[1]]

        pre_rows = self.generate(numRows - 1)
        pre_row = pre_rows[-1]
        curr_row = [1]

        for i in range(1, numRows - 1):
            curr_row.append(pre_row[i - 1] + pre_row[i])

        curr_row.append(1)
        pre_rows.append(curr_row)

        return pre_rows
