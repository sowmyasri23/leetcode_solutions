class Solution:
    def convert(self, s: str, r: int) -> str:
        if r == 1: return s
        k=""
        for i in range(r):
            for j in range(i,len(s),2*(r-1)):
                k+=s[j]
                if(i>0 and i<r-1 and j+2*(r-1)-2*i < len(s)):
                    k+=s[j+2*(r-1)-2*i]
        return k
