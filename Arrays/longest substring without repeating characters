class Solution:
    def lengthOfLongestSubstring(self, s: str) -> int:
        left = 0
        string = {}
        out = 0
        
        for right, current in enumerate(s):
            if current in string:
                left = max(left, string[current] + 1)
            out = max(out, right - left + 1)
            string[current] = right

        return out
